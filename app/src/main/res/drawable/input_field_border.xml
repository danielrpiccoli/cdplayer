<?xml version="1.0" encoding="utf-8"?>
<!--
    Win98 sunken (inset) border: dark gray top/left, white bottom/right.
    Opposite of window_border — used for text input fields.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#8B8B8B" />
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
