<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="@string/app_name"
        android:icon="@drawable/cd_player_icon"
        android:theme="@android:style/Theme.DeviceDefault">

        <receiver
            android:name=".CdPlayerReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.cdplayer.ACTION_PLAY_PAUSE" />
                <action android:name="com.cdplayer.ACTION_NEXT" />
                <action android:name="com.cdplayer.ACTION_PREVIOUS" />
                <action android:name="com.cdplayer.ACTION_STOP" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/cd_player_widget_info" />
        </receiver>

        <service
            android:name=".MediaListenerService"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
